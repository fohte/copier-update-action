{
  "name": "copier-update-action",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map",
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "diff": "9.0.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.5",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.2",
    "@types/semver": "7.7.1",
    "@vercel/ncc": "0.44.1",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "version": "0.1.3"
}
